        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;%%{ init: { &#39;themeVariables&#39;: { &#39;fontFamily&#39;: &#39;Microsoft YaHei, PingFang SC, Hiragino Sans GB, sans-serif&#39; } } }%%\nflowchart TD\nclassDef startend fill:#0f172a,color:#fff,stroke:#1e293b,stroke-width:2px,font-weight:700\nclassDef manual fill:#eff6ff,stroke:#2563eb,color:#1e3a8a,stroke-width:1.5px\nclassDef auto fill:#f0fdfa,stroke:#0d9488,color:#065f46,stroke-width:1.5px,stroke-dasharray:5 3\nclassDef ctrl fill:#fffbeb,stroke:#d97706,color:#92400e,stroke-width:2px\nclassDef ext fill:#f5f3ff,stroke:#7c3aed,color:#5b21b6,stroke-width:1.5px\nclassDef flow fill:#f1f5f9,stroke:#475569,color:#334155,stroke-width:1.5px\nclassDef dec fill:#fff1f2,stroke:#be123c,color:#9f1239,stroke-width:2px\nSTART([\&quot;开始 · 合作出口业务\&quot;]):::startend\nCFG[\&quot;合作方结算方式维护&lt;br/&gt;（结算方式 / 预付比例 / 费用额度）\&quot;]:::flow\nSTART --&gt; CFG\nsubgraph P1[\&quot;阶段 1 · 出运管理 —— 业务起点\&quot;]\n  SHIP1[\&quot;手工新建【合作出口出运单】&lt;br/&gt;录入 销售主信息(1份) + 国内采购(多条)\&quot;]:::manual\n  SHIP2[\&quot;《提交》生效&lt;br/&gt;出运单:审批单:销合同:采合同 = 1:1:1:N\&quot;]:::manual\n  A1[\&quot;合同审批单(销售)\&quot;]:::auto\n  A2[\&quot;销售合同\&quot;]:::auto\n  A3[\&quot;采购合同 1:N\&quot;]:::auto\n  A4[\&quot;采购入仓单\&quot;]:::auto\n  A5[\&quot;销售出仓单\&quot;]:::auto\n  SHIP1 --&gt; SHIP2\n  SHIP2 -. 系统自动生成 .-&gt; A1\n  SHIP2 -.-&gt; A2 &amp; A3 &amp; A4 &amp; A5\nend\nCFG --&gt; SHIP1\nsubgraph P2[\&quot;阶段 2 · 单证管理 —— 报关\&quot;]\n  DRAFT[\&quot;拷贝【出运单】→ 出口报关草单&lt;br/&gt;《生成报关商品》→ 报关单证\&quot;]:::manual\n  WIN[\&quot;单一窗口《获取报关单》&lt;br/&gt;出口电子报关单\&quot;]:::ext\n  GATE{{\&quot;★ 关键控制点 · 认领报关单&lt;br/&gt;须 已结关 + 有出口日期 + 金额/数量一致\&quot;}}:::ctrl\n  DRAFT --&gt; WIN --&gt; GATE\nend\nSHIP2 --&gt; DRAFT\nsubgraph P3[\&quot;阶段 3 · 发票管理\&quot;]\n  PINV[\&quot;出口国内采购发票&lt;br/&gt;（拷贝出运单拣配明细）\&quot;]:::manual\n  SINV[\&quot;出口销售发票&lt;br/&gt;⚠ 前置:须认领报关单\&quot;]:::manual\n  FINV[\&quot;出口费用发票&lt;br/&gt;（非货款类费用）\&quot;]:::manual\n  AP[\&quot;生效 → 成本认定 + 应付往来&lt;br/&gt;→《生成付款单》\&quot;]:::flow\n  AR[\&quot;生效 → 应收往来\&quot;]:::flow\n  APE[\&quot;生效 → 应付往来&lt;br/&gt;→ 付款申请单\&quot;]:::flow\n  PINV --&gt; AP\n  SINV --&gt; AR\n  FINV --&gt; APE\nend\nGATE --&gt; PINV &amp; SINV &amp; FINV\nsubgraph P4[\&quot;阶段 4 · 资金收付\&quot;]\n  REC[\&quot;境外收款登记&lt;br/&gt;→ 自动生成收款认领单\&quot;]:::manual\n  RCLAIM[\&quot;境外收款认领&lt;br/&gt;拆分认定到 合同/结算单/销售发票\&quot;]:::manual\n  PAY[\&quot;付款申请单&lt;br/&gt;→ 财务支付工作台 → 出纳支付\&quot;]:::manual\n  REC --&gt; RCLAIM\nend\nAP -.-&gt; PAY\nAPE -.-&gt; PAY\nAR -. 应收认定 .-&gt; RCLAIM\nsubgraph P5[\&quot;阶段 5 · 结算管理 —— 成本与利润核算\&quot;]\n  SETT[\&quot;拷贝【出运单】→ 出口结算单&lt;br/&gt;⚠ 前置:须认领报关单\&quot;]:::manual\n  DEC{{\&quot;选择结算方案\&quot;}}:::dec\n  SA[\&quot;方案 A 固定收汇-算厂价&lt;br/&gt;生效: 改采购合同版本 + 预收款冲销单\&quot;]:::manual\n  SB[\&quot;方案 B 固定厂价-算耗汇&lt;br/&gt;生效: 系统无后续处理\&quot;]:::manual\n  SC[\&quot;方案 C 固定厂价-固定收汇&lt;br/&gt;生效: 结算盈余往来 + 预收款冲销单\&quot;]:::manual\n  SETT --&gt; DEC\n  DEC --&gt;|方案 A| SA\n  DEC --&gt;|方案 B| SB\n  DEC --&gt;|方案 C| SC\nend\nRCLAIM -. 耗汇数据 .-&gt; SETT\nDONE([\&quot;全流程闭环 · 单证 / 发票 / 资金 / 结算 全部落地\&quot;]):::startend\nPAY --&gt; DONE\nSA &amp; SB &amp; SC --&gt; DONE&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="qRz5WPGjfO86WkayBmkP-1">
